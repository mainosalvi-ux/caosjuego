rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProfile(data) {
      return data.keys().hasAll(['displayName']) &&
             data.keys().size() <= 3 &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             (!data.keys().contains('avatar') || (data.avatar is string && data.avatar.size() <= 500));
    }

    function isValidDeck(data) {
      return data.keys().hasAll(['title', 'creatorId', 'whiteCards', 'blackCards']) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             data.creatorId == request.auth.uid &&
             data.whiteCards is list && data.whiteCards.size() <= 500 &&
             data.blackCards is list && data.blackCards.size() <= 500;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['hostId', 'deckId', 'status', 'round']) &&
             data.hostId == request.auth.uid &&
             data.deckId is string &&
             data.status in ['waiting', 'playing', 'voting', 'ended'] &&
             data.round is number &&
             (!data.keys().contains('currentBlackCard') || data.currentBlackCard == null || data.currentBlackCard is string) &&
             (!data.keys().contains('createdAt') || data.createdAt == request.time || data.createdAt is timestamp) &&
             (!data.keys().contains('timerEnd') || data.timerEnd is number);
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['userId', 'displayName', 'score']) &&
             data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 &&
             data.score is number &&
             (!data.keys().contains('hand') || data.hand is list) &&
             (!data.keys().contains('selectedCard') || data.selectedCard == null || data.selectedCard is string) &&
             (!data.keys().contains('isReady') || data.isReady is bool) &&
             (!data.keys().contains('hasVoted') || data.hasVoted is bool) &&
             (!data.keys().contains('votedFor') || data.votedFor == null || data.votedFor is string);
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'displayName', 'text', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 500 &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    match /decks/{deckId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && existing().creatorId == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        (existing().hostId == request.auth.uid) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'currentBlackCard', 'round', 'timerEnd']))
      );

      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && (
          isOwner(participantId) || 
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid
        );
      }

      match /chat/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidChatMessage(incoming());
      }
    }
  }
}
